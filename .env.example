# .env.example
# Application Settings
PROJECT_NAME="Agent_OS"
ENVIRONMENT="production" # development, production, test

# Database Configuration
# Use ${POSTGRES_USER} and ${POSTGRES_PASSWORD} in docker-compose
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=<CHANGE_ME_SECURE_PASSWORD>
POSTGRES_DB=agent_os
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"

# Cache & Message Broker (Valkey)
REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Secret Generation Hints:
# Generate a secure secret: openssl rand -hex 32
# Vault write hint: vault write -f auth/approle/role/agent-os-role secret_id_ttl=10m
